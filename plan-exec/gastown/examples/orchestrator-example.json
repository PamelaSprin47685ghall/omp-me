{
  "description": "Orchestrator Protocol 使用示例",
  "main": "async function main(task)",
  "flow": [
    "await main(task, '实现 OAuth2 + JWT 认证系统')"
  ],
  "topology": "dag",
  "graph": {
    "nodes": [
      { "id": "oauth2-config", "run": "配置 OAuth2 提供商" },
      { "id": "jwt-impl",      "run": "TDD 实现 JWT 生成与验证" },
      { "id": "session-store", "run": "实现 session 存储后端" },
      { "id": "api-integ",     "run": "Review-Loop 集成 auth 中间件" }
    ],
    "edges": [
      { "from": "oauth2-config", "to": "jwt-impl" },
      { "from": "jwt-impl",      "to": "api-integ" },
      { "from": "session-store", "to": "api-integ" }
    ]
  },
  "gate": {
    "mode": "majority",
    "ballots": [
      { "voterId": "refinery", "vote": "检查 API 一致性" },
      { "voterId": "crew-lead", "vote": "审查架构连贯性" }
    ]
  }
}
