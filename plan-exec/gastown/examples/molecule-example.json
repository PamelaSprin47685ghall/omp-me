{
  "description": "Molecule Protocol 使用示例",
  "main": "async function main(task, steps, opts)",
  "steps": [
    { "type": "task",    "run": "分析需求" },
    { "type": "dag",     "graph": { "nodes": [...], "edges": [...] } },
    { "type": "review",  "author": "...", "reviewers": ["..."] },
    { "type": "tdd",     "red": "...", "green": "...", "refactor": "..." },
    { "type": "gatekeeper", "config": { "mode": "majority" }, "ballots": [...] },
    { "type": "task",    "run": "合并并打标签" }
  ],
  "opts": {
    "checkpointInterval": 2
  }
}
