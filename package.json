{
  "name": "oh-my-pi-plugins",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "bun run test:squad && bun run test:tau && bun run test:deep-think && bun run test:s2u && bun run test:head && bun run test:search",
    "test:squad": "bun test squad/",
    "test:tau": "bun test oh-tau-mirror/",
    "test:deep-think": "bun test deep-think/",
    "test:s2u": "bun test degrade/",
    "test:head": "bun test block-head-tail/",
    "test:search": "bun test ollama-search/",
    "prepare": "simple-git-hooks",
    "format": "bun x prettier --write \"**/*.{js,mjs}\"",
    "format:check": "bun x prettier --check \"**/*.{js,mjs}\""
  },
  "alias": {
    "@earendil-works/pi-ai": "@mariozechner/pi-ai",
    "@earendil-works/pi-coding-agent": "@mariozechner/pi-coding-agent",
    "@earendil-works/pi-tui": "@mariozechner/pi-tui"
  },
  "dependencies": {
    "@blueprintjs/core": "^6.12.1",
    "@blueprintjs/icons": "^6.9.1",
    "@juicesharp/rpiv-advisor": "^1.4.0",
    "@mariozechner/pi-ai": "file:shim-packages/pi-ai",
    "@mariozechner/pi-coding-agent": "file:shim-packages/pi-coding-agent",
    "@mariozechner/pi-tui": "file:shim-packages/pi-tui",
    "@oh-my-pi/resolve-pi": "file:shim-packages/pi-resolve",
    "@sinclair/typebox": "^0.34.49",
    "mermaid": "^11.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tau-mirror": "^1.0.7",
    "typebox": "file:shim-packages/typebox",
    "vite": "^8.0.11",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "happy-dom": "^20.9.0",
    "lint-staged": "^15.5.2",
    "puppeteer": "^24.43.0",
    "simple-git-hooks": "^2.13.1"
  },
  "lint-staged": {
    "*.{js,mjs}": "bun x prettier --write"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  }
}
