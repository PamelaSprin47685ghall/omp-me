{
  "name": "oh-my-pi-plugins",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "simple-git-hooks",
    "format": "prettier --write \"**/*.js\"",
    "format:check": "prettier --check \"**/*.js\""
  },
  "devDependencies": {
    "lint-staged": "^15.5.2",
    "simple-git-hooks": "^2.12.1"
  },
  "lint-staged": {
    "*.js": "bun x prettier --write"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  }
}
